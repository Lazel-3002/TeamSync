{
  "name": "teamsync",
  "version": "1.0.0",
  "description": "P2P sesli/görüntülü/ekran paylaşımı + uzaktan kontrol - sunucusuz",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "diag": "cross-env DIAG=1 electron .",
    "dev:react": "cross-env REACT_DEV=true concurrently \"vite\" \"electron .\"",
    "build:react": "vite build",
    "build": "electron-builder --win portable --x64",
    "build-full": "electron-builder --win --x64",
    "test:e2e": "node test/e2e/run-all.js"
  },
  "author": "TeamSync",
  "license": "MIT",
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "@jitsi/robotjs": "^0.6.22",
    "@sapphi-red/web-noise-suppressor": "0.3.5",
    "@supabase/supabase-js": "^2.110.0",
    "acorn": "^8.17.0",
    "cross-fetch": "^4.1.0",
    "crypto-js": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "com.TeamSync.voice",
    "productName": "TeamSync",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules",
      "!dist",
      "!.env",
      "!tools/dev/yapaydenetleyici.js",
      "!problemler.md",
      "!yapaydenetliyici.md"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
